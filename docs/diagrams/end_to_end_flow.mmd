flowchart LR
    subgraph S1["<b>1. DEFINE</b>"]
        SCHEMA["<b>schema/commands/_motion.py</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>MOTION_COMMANDS = {<br/>  'CMD_SET_VEL': {<br/>    'payload': {<br/>      'vx': {'type': 'float'},<br/>      'omega': {'type': 'float'}<br/>    }<br/>  }<br/>}"]
    end

    subgraph S2["<b>2. GENERATE</b>"]
        direction TB
        GEN["<b>mara generate all</b>"]
        subgraph OUTS[" "]
            direction LR
            PY["<b>Python</b><br/>command_defs.py<br/>client_commands.py"]
            CPP["<b>C++</b><br/>CommandDefs.h<br/>BinaryCommands.h"]
        end
        GEN --> OUTS
    end

    subgraph S3["<b>3. MCU HANDLER</b>"]
        MCU["<b>MotionHandler.h</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>class MotionHandler<br/>  : public ICommandHandler {<br/><br/>  void handle(...) {<br/>    intents->setVelocity(<br/>      payload['vx'],<br/>      payload['omega']<br/>    );<br/>  }<br/>};"]
    end

    subgraph S4["<b>4. HOST SERVICE</b>"]
        HOST["<b>motion_service.py</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>class MotionService:<br/><br/>  async def set_velocity(<br/>      self, vx, omega, binary=True<br/>  ):<br/>    await self.client.send_stream(<br/>      'CMD_SET_VEL',<br/>      {'vx': vx, 'omega': omega},<br/>      binary=binary<br/>    )"]
    end

    subgraph S5["<b>5. USE IT</b>"]
        APP["<b>my_app.py</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>from mara_host import Robot<br/><br/>async with Robot('/dev/tty') as robot:<br/>    await robot.arm()<br/>    await robot.activate()<br/><br/>    # High-rate streaming (binary)<br/>    await robot.motion.set_velocity(<br/>      vx=0.5, omega=0.0<br/>    )<br/><br/>    await robot.motion.stop()"]
    end

    subgraph S6["<b>6. RUNTIME</b>"]
        direction TB
        subgraph FLOWS[" "]
            direction LR
            CMD_PATH["<b>Command →</b><br/>API → Service<br/>→ Commander<br/>→ Transport → MCU"]
            TELEM_PATH["<b>← Telemetry</b><br/>Sensor → Pack<br/>→ Frame → Parse<br/>→ EventBus"]
        end
    end

