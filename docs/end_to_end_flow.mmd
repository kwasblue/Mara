}}%%

flowchart TB
    subgraph STEP1["<b>① DEFINE</b> — Edit Schema"]
        direction TB
        S1_DESC["Add your command/telemetry to the single source of truth"]

        SCHEMA["<b>📝 platform_schema.py</b><br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/><br/>COMMANDS = {<br/>  'CMD_MY_SENSOR_READ': {<br/>    'kind': 'cmd',<br/>    'direction': 'host→mcu',<br/>    'payload': {'sensor_id': {...}}<br/>  }<br/>}<br/><br/>TELEMETRY_SECTIONS = {<br/>  'TELEM_MY_SENSOR': {<br/>    'id': 0x20,<br/>    'format': 'id(u8) value(f32)',<br/>    'size': 5<br/>  }<br/>}"]
    end

    subgraph STEP2["<b>② GENERATE</b> — Run Codegen"]
        direction TB
        S2_DESC["Single command generates matching Python + C++ code"]

        GEN["<b>⚙️ python generate_all.py</b>"]

        subgraph OUTPUTS["Generated Files"]
            direction LR
            subgraph PY_OUT["<b>🐍 Python</b>"]
                PY1["command_defs.py"]
                PY2["telemetry_sections.py"]
                PY3["client_commands.py"]
            end
            subgraph CPP_OUT["<b>⚡ C++</b>"]
                CPP1["CommandDefs.h"]
                CPP2["TelemetrySections.h"]
                CPP3["BinaryCommands.h"]
            end
        end
    end

    subgraph STEP3["<b>③ IMPLEMENT MCU</b> — Add Handler"]
        direction TB
        S3_DESC["Create self-registering handler (1 file)"]

        MCU_CODE["<b>📄 MySensorHandler.h</b><br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/><br/>class MySensorHandler : public IStringHandler {<br/>public:<br/>  static constexpr const char* CMDS[] = {<br/>    'CMD_MY_SENSOR_READ', nullptr<br/>  };<br/><br/>  void handle(const char* cmd,<br/>              JsonVariantConst payload,<br/>              CommandContext& ctx) override {<br/>    int id = payload['sensor_id'];<br/>    float val = readSensor(id);<br/>    ctx.sendAck(cmd, true, {{'value', val}});<br/>  }<br/>};<br/><br/>REGISTER_HANDLER(MySensorHandler);"]
    end

    subgraph STEP4["<b>④ IMPLEMENT HOST</b> — Add Module"]
        direction TB
        S4_DESC["Create BaseModule for your feature"]

        HOST_CODE["<b>📄 my_sensor.py</b><br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/><br/>from robot_host import BaseModule<br/>from robot_host.telemetry.telemetry_sections import TELEM_MY_SENSOR<br/><br/>class MySensorModule(BaseModule):<br/>    name = 'my_sensor'<br/><br/>    def topics(self):<br/>        return ['telemetry.my_sensor']<br/><br/>    def on_telemetry_my_sensor(self, data):<br/>        self.latest_value = data['value']<br/>        print(f'Sensor: {data}')<br/><br/>    async def read(self, sensor_id: int):<br/>        return await self._robot.client.cmd_my_sensor_read(<br/>            sensor_id=sensor_id<br/>        )"]
    end

    subgraph STEP5["<b>⑤ USE IT</b> — Full Application"]
        direction TB
        S5_DESC["Everything wired up and working"]

        APP_CODE["<b>📄 my_app.py</b><br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/><br/>from robot_host import Robot, Runtime<br/>from my_sensor import MySensorModule<br/><br/>async def main():<br/>    async with Robot('/dev/ttyUSB0') as robot:<br/>        # Add your module<br/>        sensor = MySensorModule()<br/>        runtime = Runtime(robot, tick_hz=50)<br/>        runtime.add_module(sensor)<br/><br/>        # Use it!<br/>        await robot.arm()<br/>        value = await sensor.read(sensor_id=0)<br/>        print(f'Read: {value}')<br/><br/>        # Or run continuous loop<br/>        await runtime.run(duration=10.0)"]
    end

    subgraph RUNTIME["<b>⑥ RUNTIME</b> — Data Flow"]
        direction LR

        subgraph CMD_FLOW["<b>Command Path</b>"]
            direction TB
            CF1["sensor.read(0)"]
            CF2["Client encodes"]
            CF3["Frame sent"]
            CF4["MCU handler"]
            CF5["Response"]
        end

        subgraph TELEM_FLOW["<b>Telemetry Path</b>"]
            direction TB
            TF1["MCU sensor read"]
            TF2["Pack section 0x20"]
            TF3["Frame sent"]
            TF4["Parser decodes"]
            TF5["EventBus publishes"]
            TF6["Module callback"]
        end
    end

    %% Flow connections
    STEP1 --> STEP2
    STEP2 --> STEP3
    STEP2 --> STEP4
    STEP3 --> STEP5
    STEP4 --> STEP5
    STEP5 --> RUNTIME

    SCHEMA --> GEN
    GEN --> PY_OUT
    GEN --> CPP_OUT

    CF1 --> CF2 --> CF3 --> CF4 --> CF5
    TF1 --> TF2 --> TF3 --> TF4 --> TF5 --> TF6

