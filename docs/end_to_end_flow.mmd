flowchart LR
    subgraph S1["<b>① DEFINE</b>"]
        SCHEMA["<b>📝 platform_schema.py</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>COMMANDS = {<br/>  'CMD_MY_SENSOR': {...}<br/>}<br/><br/>TELEMETRY_SECTIONS = {<br/>  'TELEM_MY_SENSOR': {<br/>    'id': 0x20,<br/>    'format': 'id(u8) val(f32)'<br/>  }<br/>}"]
    end

    subgraph S2["<b>② GENERATE</b>"]
        direction TB
        GEN["<b>⚙️ python generate_all.py</b>"]
        subgraph OUTS[" "]
            direction LR
            PY["<b>🐍 Python</b><br/>telemetry_sections.py<br/>client_commands.py"]
            CPP["<b>⚡ C++</b><br/>TelemetrySections.h<br/>CommandDefs.h"]
        end
        GEN --> OUTS
    end

    subgraph S3["<b>③ MCU HANDLER</b>"]
        MCU["<b>📄 MySensorHandler.h</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>class MySensorHandler<br/>  : public IStringHandler {<br/><br/>  void handle(...) {<br/>    float val = readSensor();<br/>    ctx.sendAck(cmd, val);<br/>  }<br/>};<br/><br/>REGISTER_HANDLER(...);"]
    end

    subgraph S4["<b>④ HOST MODULE</b>"]
        HOST["<b>📄 my_sensor.py</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>class MySensorModule(BaseModule):<br/>    name = 'my_sensor'<br/><br/>    def topics(self):<br/>        return ['telemetry.my_sensor']<br/><br/>    def on_telemetry_my_sensor(self, d):<br/>        self.value = d['value']<br/><br/>    async def read(self, id):<br/>        return await self._robot<br/>          .client.cmd_my_sensor(id)"]
    end

    subgraph S5["<b>⑤ USE IT</b>"]
        APP["<b>📄 my_app.py</b><br/>━━━━━━━━━━━━━━━━━━━━<br/>from robot_host import Robot, Runtime<br/>from my_sensor import MySensorModule<br/><br/>async with Robot('/dev/tty') as robot:<br/>    sensor = MySensorModule()<br/>    runtime = Runtime(robot, tick_hz=50)<br/>    runtime.add_module(sensor)<br/><br/>    await robot.arm()<br/>    val = await sensor.read(0)<br/>    await runtime.run(duration=10)"]
    end

    subgraph S6["<b>⑥ RUNTIME</b>"]
        direction TB
        subgraph FLOWS[" "]
            direction LR
            CMD_PATH["<b>Command →</b><br/>read(0) → Client<br/>→ Frame → MCU<br/>→ Handler → ACK"]
            TELEM_PATH["<b>← Telemetry</b><br/>Sensor → Pack<br/>→ Frame → Parse<br/>→ EventBus → Module"]
        end
    end

    S1 --> S2 --> S3
    S2 --> S4
    S3 --> S5
    S4 --> S5
    S5 --> S6

