{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MARA Control Graph",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "slots": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/slot"
      }
    }
  },
  "required": [
    "schema_version",
    "slots"
  ],
  "definitions": {
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "source": {
          "title": "source",
          "oneOf": [
            {
              "title": "constant",
              "description": "Publish a constant scalar value each tick.",
              "type": "object",
              "properties": {
                "type": {
                  "const": "constant"
                },
                "params": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "float",
                      "description": "Constant scalar value to publish.",
                      "default": 0.0
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "title": "encoder_velocity",
              "description": "Read encoder velocity (rad/s) as slot input. Provides feedback for velocity control loops.",
              "type": "object",
              "properties": {
                "type": {
                  "const": "encoder_velocity"
                },
                "params": {
                  "type": "object",
                  "properties": {
                    "encoder_id": {
                      "type": "int",
                      "description": "Encoder channel ID (0-7).",
                      "minimum": 0,
                      "maximum": 7
                    },
                    "ticks_per_rad": {
                      "type": "float",
                      "description": "Encoder ticks per radian. Used to convert tick rate to rad/s.",
                      "default": 1.0,
                      "minimum": 0.001
                    },
                    "fallback": {
                      "type": "float",
                      "description": "Value to use if encoder is not available or not initialized.",
                      "default": 0.0
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "encoder_id"
                  ]
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "title": "imu_axis",
              "description": "Read a derived orientation axis from the IMU.",
              "type": "object",
              "properties": {
                "type": {
                  "const": "imu_axis"
                },
                "params": {
                  "type": "object",
                  "properties": {
                    "axis": {
                      "type": "enum",
                      "description": "Derived tilt axis to publish.",
                      "enum": [
                        "pitch",
                        "roll"
                      ]
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "axis"
                  ]
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "title": "signal_read",
              "description": "Read a signal value from the signal bus as slot input. Enables cross-slot communication and feedback loops.",
              "type": "object",
              "properties": {
                "type": {
                  "const": "signal_read"
                },
                "params": {
                  "type": "object",
                  "properties": {
                    "signal_id": {
                      "type": "int",
                      "description": "Signal ID to read from (must be pre-defined in signal bus).",
                      "minimum": 0,
                      "maximum": 255
                    },
                    "fallback": {
                      "type": "float",
                      "description": "Value to use if signal is not defined or not yet written.",
                      "default": 0.0
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "signal_id"
                  ]
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            }
          ],
          "discriminator": {
            "propertyName": "type",
            "mapping": {
              "constant": "#/definitions/source/constant",
              "encoder_velocity": "#/definitions/source/encoder_velocity",
              "imu_axis": "#/definitions/source/imu_axis",
              "signal_read": "#/definitions/source/signal_read"
            }
          }
        },
        "transforms": {
          "type": "array",
          "items": {
            "title": "transform",
            "oneOf": [
              {
                "title": "abs",
                "description": "Output absolute value of input.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "abs"
                  },
                  "params": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "clamp",
                "description": "Clamp the input signal to a configured range.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "clamp"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "min": {
                        "type": "float",
                        "description": "Lower bound.",
                        "default": -1.0
                      },
                      "max": {
                        "type": "float",
                        "description": "Upper bound.",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "deadband",
                "description": "Suppress small input values around zero.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "deadband"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "threshold": {
                        "type": "float",
                        "description": "Magnitude below which the output is forced to zero.",
                        "default": 0.0,
                        "minimum": 0.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "delta_gate",
                "description": "Emit a new value only when it changes by at least a threshold from the last emitted value.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "delta_gate"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "threshold": {
                        "type": "float",
                        "description": "Minimum absolute change required before a new value is emitted.",
                        "default": 0.0,
                        "minimum": 0.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "derivative",
                "description": "Compute rate of change of input (dv/dt). Useful for predictive/damping control.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "derivative"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "gain": {
                        "type": "float",
                        "description": "Multiplier applied to the derivative output.",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "error",
                "description": "Compute control error: current value (setpoint) minus feedback signal. Commonly used as first stage in PID loops.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "error"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "feedback_signal": {
                        "type": "int",
                        "description": "Signal ID containing feedback/measurement value.",
                        "minimum": 0,
                        "maximum": 255
                      },
                      "fallback": {
                        "type": "float",
                        "description": "Feedback value to use if signal is not defined.",
                        "default": 0.0
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "feedback_signal"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "hysteresis",
                "description": "Schmitt trigger with separate on/off thresholds to prevent chattering.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "hysteresis"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "on_threshold": {
                        "type": "float",
                        "description": "Threshold to turn on (input must exceed this to go high).",
                        "default": 0.5
                      },
                      "off_threshold": {
                        "type": "float",
                        "description": "Threshold to turn off (input must drop below this to go low).",
                        "default": 0.3
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "integrator",
                "description": "Accumulate input over time (integral). Includes anti-windup bounds.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "integrator"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "gain": {
                        "type": "float",
                        "description": "Multiplier applied to input before integrating.",
                        "default": 1.0
                      },
                      "min": {
                        "type": "float",
                        "description": "Anti-windup lower bound for accumulated value.",
                        "default": -1000.0
                      },
                      "max": {
                        "type": "float",
                        "description": "Anti-windup upper bound for accumulated value.",
                        "default": 1000.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "lowpass",
                "description": "First-order exponential smoothing filter.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "lowpass"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "alpha": {
                        "type": "float",
                        "description": "Smoothing factor; higher tracks the input more aggressively.",
                        "default": 0.5,
                        "minimum": 0.0,
                        "maximum": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "map",
                "description": "Linearly remap input from one range to another.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "map"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "in_min": {
                        "type": "float",
                        "description": "Input range minimum.",
                        "default": 0.0
                      },
                      "in_max": {
                        "type": "float",
                        "description": "Input range maximum.",
                        "default": 1.0
                      },
                      "out_min": {
                        "type": "float",
                        "description": "Output range minimum.",
                        "default": 0.0
                      },
                      "out_max": {
                        "type": "float",
                        "description": "Output range maximum.",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "median",
                "description": "Rolling median filter (5-sample window). Rejects outlier spikes better than lowpass.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "median"
                  },
                  "params": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "negate",
                "description": "Flip the sign of the input value.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "negate"
                  },
                  "params": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "offset",
                "description": "Add a constant offset to the input signal.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "offset"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "value": {
                        "type": "float",
                        "description": "Constant value added to the input.",
                        "default": 0.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "oscillator",
                "description": "Generate sine wave output. Input is ignored; output is offset + amplitude * sin(phase).",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "oscillator"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "frequency": {
                        "type": "float",
                        "description": "Oscillation frequency in Hz.",
                        "default": 1.0,
                        "minimum": 0.001,
                        "unit": "Hz"
                      },
                      "amplitude": {
                        "type": "float",
                        "description": "Peak amplitude of the sine wave.",
                        "default": 1.0
                      },
                      "offset": {
                        "type": "float",
                        "description": "DC offset added to the sine wave.",
                        "default": 0.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "proportional",
                "description": "Proportional gain (P term). Multiplies input by gain factor.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "proportional"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "gain": {
                        "type": "float",
                        "description": "Proportional gain factor (Kp).",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "pulse",
                "description": "Generate periodic pulses. Input is ignored.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "pulse"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "interval_ms": {
                        "type": "float",
                        "description": "Time between pulse starts in milliseconds.",
                        "default": 1000.0,
                        "minimum": 1.0,
                        "unit": "ms"
                      },
                      "duration_ms": {
                        "type": "float",
                        "description": "Pulse duration in milliseconds.",
                        "default": 100.0,
                        "minimum": 1.0,
                        "unit": "ms"
                      },
                      "value": {
                        "type": "float",
                        "description": "Output value during pulse (0 otherwise).",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "recall",
                "description": "Retrieve value from a named tap. Replaces current value with tap value.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "recall"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Name of the tap to recall from (must match a tap defined earlier in the slot)."
                      },
                      "fallback": {
                        "type": "float",
                        "description": "Value to use if tap not found.",
                        "default": 0.0
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "name"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "scale",
                "description": "Multiply the input signal by a scalar factor.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "scale"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "factor": {
                        "type": "float",
                        "description": "Scalar multiplier applied to the input.",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "signal_add",
                "description": "Add a signal value from the signal bus to the current value. Useful for merging parallel slot outputs.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "signal_add"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "signal_id": {
                        "type": "int",
                        "description": "Signal ID to read and add (must be pre-defined in signal bus).",
                        "minimum": 0,
                        "maximum": 255
                      },
                      "fallback": {
                        "type": "float",
                        "description": "Value to add if signal is not defined or not yet written.",
                        "default": 0.0
                      },
                      "scale": {
                        "type": "float",
                        "description": "Scale factor applied to signal value before adding.",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "signal_id"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "signal_recall",
                "description": "Replace current value with a signal from the signal bus. Similar to recall but reads from signal bus instead of local taps.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "signal_recall"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "signal_id": {
                        "type": "int",
                        "description": "Signal ID to read from (must be pre-defined in signal bus).",
                        "minimum": 0,
                        "maximum": 255
                      },
                      "fallback": {
                        "type": "float",
                        "description": "Value to use if signal is not defined or not yet written.",
                        "default": 0.0
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "signal_id"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "signal_subtract",
                "description": "Subtract a signal value from the current value. Result is: current - signal.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "signal_subtract"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "signal_id": {
                        "type": "int",
                        "description": "Signal ID to read and subtract (must be pre-defined in signal bus).",
                        "minimum": 0,
                        "maximum": 255
                      },
                      "fallback": {
                        "type": "float",
                        "description": "Value to subtract if signal is not defined or not yet written.",
                        "default": 0.0
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "signal_id"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "slew_rate",
                "description": "Limit how quickly the output is allowed to change, in output units per second.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "slew_rate"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "rate": {
                        "type": "float",
                        "description": "Maximum absolute output change per second.",
                        "default": 0.0,
                        "minimum": 0.0,
                        "unit": "units/s"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "sum",
                "description": "Sum values from multiple named taps. Enables MISO (multiple-input, single-output) patterns like PID.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "sum"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "inputs": {
                        "type": "string_list",
                        "description": "List of tap names to sum together (max 4)."
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "inputs"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "tap",
                "description": "Store current value to a named tap for recall by other transforms. Passes value through unchanged.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "tap"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Name of the tap (max 11 chars). Used by recall/sum to reference this value."
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "name"
                    ]
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "threshold",
                "description": "Binary output based on cutoff value.",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "threshold"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "cutoff": {
                        "type": "float",
                        "description": "Threshold cutoff value.",
                        "default": 0.5
                      },
                      "output_low": {
                        "type": "float",
                        "description": "Output value when input is below cutoff.",
                        "default": 0.0
                      },
                      "output_high": {
                        "type": "float",
                        "description": "Output value when input is at or above cutoff.",
                        "default": 1.0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "title": "toggle",
                "description": "Flip output state each time input crosses threshold (rising edge).",
                "type": "object",
                "properties": {
                  "type": {
                    "const": "toggle"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "threshold": {
                        "type": "float",
                        "description": "Threshold for detecting rising edge.",
                        "default": 0.5
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              }
            ],
            "discriminator": {
              "propertyName": "type",
              "mapping": {
                "abs": "#/definitions/transform/abs",
                "clamp": "#/definitions/transform/clamp",
                "deadband": "#/definitions/transform/deadband",
                "delta_gate": "#/definitions/transform/delta_gate",
                "derivative": "#/definitions/transform/derivative",
                "error": "#/definitions/transform/error",
                "hysteresis": "#/definitions/transform/hysteresis",
                "integrator": "#/definitions/transform/integrator",
                "lowpass": "#/definitions/transform/lowpass",
                "map": "#/definitions/transform/map",
                "median": "#/definitions/transform/median",
                "negate": "#/definitions/transform/negate",
                "offset": "#/definitions/transform/offset",
                "oscillator": "#/definitions/transform/oscillator",
                "proportional": "#/definitions/transform/proportional",
                "pulse": "#/definitions/transform/pulse",
                "recall": "#/definitions/transform/recall",
                "scale": "#/definitions/transform/scale",
                "signal_add": "#/definitions/transform/signal_add",
                "signal_recall": "#/definitions/transform/signal_recall",
                "signal_subtract": "#/definitions/transform/signal_subtract",
                "slew_rate": "#/definitions/transform/slew_rate",
                "sum": "#/definitions/transform/sum",
                "tap": "#/definitions/transform/tap",
                "threshold": "#/definitions/transform/threshold",
                "toggle": "#/definitions/transform/toggle"
              }
            }
          },
          "default": []
        },
        "sink": {
          "title": "sink",
          "oneOf": [
            {
              "title": "gpio_write",
              "description": "Drive a logical GPIO output from a scalar signal.",
              "type": "object",
              "properties": {
                "type": {
                  "const": "gpio_write"
                },
                "params": {
                  "type": "object",
                  "properties": {
                    "channel": {
                      "type": "int",
                      "description": "Logical GPIO channel.",
                      "minimum": 0
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "channel"
                  ]
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "title": "motor_speed",
